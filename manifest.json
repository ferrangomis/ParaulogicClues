{
  "manifest_version": 3,
  "name": "Paraulògic Pistes",
  "version": "1.1",
  "description": "Mostra i actualitza les pistes de Paraulògic mentre jugues",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [],
"content_scripts": [
    {
      "matches": ["*://www.vilaweb.cat/paraulogic/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
